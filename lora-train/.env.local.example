# Core
MODEL_ID=mistralai/Mistral-7B-Instruct-v0.2
DATA_TRAIN_PATH=data/sample_train.jsonl
DATA_EVAL_PATH=data/sample_eval.jsonl
OUTPUT_DIR=outputs
RUN_NAME=mistral7b-local-lora
SEED=42

# Training
MAX_SEQ_LEN=1024
MICRO_BATCH_SIZE=1
GRAD_ACCUM_STEPS=16
NUM_EPOCHS=1.0
LEARNING_RATE=0.0002
WARMUP_RATIO=0.03
WEIGHT_DECAY=0.0
LR_SCHEDULER=cosine
MAX_STEPS=-1
EVAL_STRATEGY=steps
SAVE_STEPS=25
EVAL_STEPS=25
LOGGING_STEPS=5

# Precision / memory
USE_QLORA=true
LOAD_IN_4BIT=true
BNB_4BIT_QUANT_TYPE=nf4
BNB_4BIT_COMPUTE_DTYPE=bfloat16
GRADIENT_CHECKPOINTING=true
BF16=true
FP16=false

# LoRA
LORA_R=16
LORA_ALPHA=32
LORA_DROPOUT=0.05
LORA_TARGET_MODULES=

# Optional
WANDB_PROJECT=
WANDB_ENTITY=
WANDB_API_KEY=
HF_TOKEN=
PUSH_TO_HUB=false
HUB_REPO_ID=
HUB_PRIVATE=true
ATTN_IMPLEMENTATION=
