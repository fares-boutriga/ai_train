# Core
MODEL_ID=Qwen/Qwen2.5-14B-Instruct
DATA_TRAIN_PATH=/workspace/lora-train/data/sample_train.jsonl
DATA_EVAL_PATH=/workspace/lora-train/data/sample_eval.jsonl
OUTPUT_DIR=/workspace/outputs
RUN_NAME=qwen25-14b-runpod-lora
SEED=42

# Training
MAX_SEQ_LEN=4096
MICRO_BATCH_SIZE=1
GRAD_ACCUM_STEPS=8
NUM_EPOCHS=1.0
LEARNING_RATE=0.00015
WARMUP_RATIO=0.03
WEIGHT_DECAY=0.01
LR_SCHEDULER=cosine
MAX_STEPS=-1
EVAL_STRATEGY=steps
SAVE_STEPS=100
EVAL_STEPS=100
LOGGING_STEPS=10

# Precision / memory
USE_QLORA=true
LOAD_IN_4BIT=true
BNB_4BIT_QUANT_TYPE=nf4
BNB_4BIT_COMPUTE_DTYPE=bfloat16
GRADIENT_CHECKPOINTING=true
BF16=true
FP16=false

# LoRA
LORA_R=32
LORA_ALPHA=64
LORA_DROPOUT=0.05
LORA_TARGET_MODULES=

# Optional
WANDB_PROJECT=
WANDB_ENTITY=
WANDB_API_KEY=
HF_TOKEN=
PUSH_TO_HUB=false
HUB_REPO_ID=
HUB_PRIVATE=true
ATTN_IMPLEMENTATION=flash_attention_2
